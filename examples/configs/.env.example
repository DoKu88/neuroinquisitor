# Copy this file to examples/configs/.env and fill in your values.
# The example script loads this file automatically via python-dotenv.
# Values here are overridden by any variables already set in the shell environment.
# YAML config values (when non-empty) take priority over these env vars.

# S3 bucket configuration
S3_BUCKET=your-bucket-name
S3_PREFIX=ni-examples
S3_REGION=us-east-1

# AWS credentials (alternatively use AWS_PROFILE or an IAM role)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
